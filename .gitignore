# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js build output
/.next/
/out/

# opennextjs / cloudflare build output
/.open-next/

# wrangler local state, D1 local db, KV cache, etc.
/.wrangler/

# drizzle generated migrations (commit if you want migration history)
# /drizzle/

# production
/build

# env files — never commit secrets
.env
.env.*
.dev.vars
!.env.example

# misc
.DS_Store
*.pem
Thumbs.db

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
