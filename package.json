{
  "name": "acm-hackathon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:cloudflare": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 execute acm-hackathon-db --local --file=./drizzle/0000_dizzy_power_pack.sql",
    "db:migrate:remote": "wrangler d1 execute acm-hackathon-db --remote --file=./drizzle/0000_dizzy_power_pack.sql",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.40.0",
    "@sentry/nextjs": "^10.40.0",
    "better-auth": "^1.4.19",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "next": "^16.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.68.1"
  }
}
